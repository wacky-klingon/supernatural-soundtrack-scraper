# Scraper: optional overrides for config/scraper.yaml (leave unset to use YAML only)
# WIKI_API_URL=
# WIKI_PAGE_TITLE=
# OUTPUT_CSV=
# OUTPUT_XLSX=

# Spotify enrichment (optional; required only for enrich command)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# INPUT_CSV=          # source soundtrack CSV (default from config/enrichment.yaml)
# OUTPUT_JSON=        # output JSON path
# OUTPUT_CSV=         # derived CSV path
# TAXONOMY_PATH=      # taxonomy YAML path
